# Claude Gateway Configuration
# 修改任何配置后重启服务即可生效

# 服务
HOST=0.0.0.0
PORT=8080

# Claude Code CLI
# Gateway 把 claude 当子进程启动，继承当前环境变量
# 不需要配置 API — Claude Code 用你现有的 CC Switch 连接
CLAUDE_CWD=E:\你的项目路径
CLAUDE_EFFORT=high

# 安全
AUTH_SECRET=改成你的随机密钥

# 文件
FILE_ROOT_DIR=E:\Claudeproject\ClaudeFiles
MAX_FILE_SIZE_MB=20
FILE_TTL_HOURS=24

# 日志
LOG_LEVEL=DEBUG
CONSOLE_MIRROR=true

# 存储
DB_PATH=./data/conversations.db

# 会话超时 超时删对话 (分钟: 0=永不, 30, 60)
SESSION_TIMEOUT_MINUTES=0

# 进程闲置超时 超时杀进程(分钟: 0=永不, 默认30)
SESSION_IDLE_TIMEOUT_MINUTES=30

# OCR (可选，使用已有 Tesseract 5.4 + Ollama qwen3-vl)
OCR_ENABLED=true

# DeepSeek 余额查询 (CC Switch 集成，可选)
# 不配不影响聊天，只影响 /api/system/info 的余额显示
# DEEPSEEK_CC_SWITCH_DB 一般不用改，PROVIDER_UUID 在 CC Switch 里找
DEEPSEEK_CC_SWITCH_DB=C:\Users\你的用户名\.cc-switch\cc-switch.db
DEEPSEEK_PROVIDER_UUID=改成你的provider-uuid
